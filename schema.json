{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/oohowba/symbolon/main/schema.json",
  "title": "Symbolon Commitment Receipt v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "receipt_id", "issuer", "principal_ref", "agent", "commitment", "events"],
  "properties": {
    "spec_version": { "const": "0.1" },
    "receipt_id": { "type": "string", "pattern": "^sym_[a-z0-9]{6,64}$" },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "id", "key_url"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "id": { "type": "string", "format": "uri", "pattern": "^https://" },
        "license": { "type": "string", "maxLength": 200 },
        "key_url": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "principal_ref": { "type": "string", "minLength": 1, "maxLength": 128 },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "on_behalf_of"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 200 },
        "on_behalf_of": { "const": "principal" }
      }
    },
    "commitment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount_decimal", "currency", "terms_url", "expires_at", "payment_reference"],
      "properties": {
        "amount_decimal": { "type": "string", "pattern": "^(?!0+(\\.0+)?$)[0-9]+(\\.[0-9]{1,4})?$" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "terms_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "terms_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "expires_at": { "type": "string", "format": "date-time" },
        "payment_reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "ref"],
          "properties": {
            "type": { "type": "string", "minLength": 1, "maxLength": 64 },
            "ref": { "type": "string", "minLength": 1, "maxLength": 256 },
            "uri": { "type": "string", "format": "uri" },
            "digest": { "type": "string", "maxLength": 128 }
          }
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "type", "at", "actor", "prev_hash", "kid", "hash", "sig"],
        "properties": {
          "seq": { "type": "integer", "minimum": 1 },
          "type": {
            "enum": [
              "intent.quote_requested",
              "commitment.charged",
              "commitment.reserved",
              "commitment.redeemed",
              "commitment.released"
            ]
          },
          "at": { "type": "string", "format": "date-time" },
          "actor": { "enum": ["agent", "principal", "issuer"] },
          "detail": {
            "type": "object",
            "maxProperties": 16,
            "additionalProperties": { "type": ["string", "integer", "boolean", "null"] }
          },
          "prev_hash": {
            "oneOf": [ { "type": "null" }, { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" } ]
          },
          "kid": { "type": "string", "minLength": 1, "maxLength": 64 },
          "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "sig": { "type": "string", "pattern": "^ed25519:[A-Za-z0-9+/]{86}==$" }
        }
      }
    }
  },
  "$defs": {
    "wellKnown": {
      "$id": "https://raw.githubusercontent.com/oohowba/symbolon/main/schema.json#well-known",
      "title": "Symbolon well-known key document (/.well-known/symbolon.json)",
      "type": "object",
      "additionalProperties": false,
      "required": ["spec_version", "keys"],
      "properties": {
        "spec_version": { "const": "0.1" },
        "keys": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kid", "alg", "pub"],
            "properties": {
              "kid": { "type": "string", "minLength": 1, "maxLength": 64 },
              "alg": { "const": "ed25519" },
              "pub": { "type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$" }
            }
          }
        }
      }
    }
  }
}
